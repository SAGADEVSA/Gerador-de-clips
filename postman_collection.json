  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/health",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "health"
          ]
        }
      },
      "response": []
    }
    ,
    {
      "name": "Upload Video (file)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "userId", "value": "user123", "type": "text" },
            { "key": "video", "type": "file" }
          ]
        },
        "url": {
          "raw": "http://localhost:5000/api/upload",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","upload"]
        }
      },
      "response": []
    },
    {
      "name": "Upload Video (YouTube URL)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{ \"userId\": \"user123\", \"youtubeUrl\": \"https://www.youtube.com/watch?v=VIDEO_ID\" }",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "http://localhost:5000/api/upload",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","upload"]
        }
      },
      "response": []
    },
    {
      "name": "Start Processing",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{ \"videoId\": \"<VIDEO_ID>\" }",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "http://localhost:5000/api/process",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","process"]
        }
      },
      "response": []
    },
    {
      "name": "Get Videos (by user)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/videos?userId=user123",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","videos"],
          "query": [ { "key": "userId", "value": "user123" } ]
        }
      },
      "response": []
    },
    {
      "name": "Get Video (by id)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/videos/<VIDEO_ID>",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","videos","<VIDEO_ID>"]
        }
      },
      "response": []
    },
    {
      "name": "Get Clips (by videoId)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/clips/<VIDEO_ID>",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","clips","<VIDEO_ID>"]
        }
      },
      "response": []
    },
    {
      "name": "Download Clip",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/clips/download/<CLIP_ID>",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","clips","download","<CLIP_ID>"]
        }
      },
      "response": []
    }
  ]
