# Database
# Use PostgreSQL for production or Docker-based setups:
DATABASE_URL="postgresql://postgres:password@localhost:5432/clipforge_ai"

# For local development without Docker, you can use SQLite:
# DATABASE_URL="file:./dev.db"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Server
PORT=5000
FRONTEND_URL="http://localhost:3000"

# External tools
YTDLP_PATH="" # Optional path to the yt-dlp executable
FFMPEG_PATH="" # Optional path to the ffmpeg executable

# File Upload
MAX_FILE_SIZE=500000000  # 500MB in bytes

# Security
JWT_SECRET="your-jwt-secret"